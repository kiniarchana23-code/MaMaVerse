rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to anyone (to view articles media)
      allow read: if true;
      // Write access is strictly limited to authenticated Admins
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}
